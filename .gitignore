```gitignore
# ============================================
# Dependencies
# ============================================
node_modules/
**/node_modules/

# ============================================
# Environment Variables
# ============================================
.env
.env.*
!.env.example

backend/.env
frontend/.env

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Build Output
# ============================================
dist/
build/
coverage/

backend/dist/
frontend/dist/

# ============================================
# Vite
# ============================================
.vite/

# ============================================
# Cache
# ============================================
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# VS Code
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ============================================
# JetBrains IDE
# ============================================
.idea/

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp

# ============================================
# Runtime Files
# ============================================
*.pid
*.seed
*.pid.lock

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/

# ============================================
# Optional Local Uploads
# (Ignore only if storing uploads locally)
# ============================================
uploads/
public/uploads/

# ============================================
# Secrets / Keys
# ============================================
*.pem
*.key
*.crt
*.p12

# ============================================
# Misc
# ============================================
*.swp
*.swo
```
